PROJECT_NAME="Society Maintenance Tracker"
ENV=development

# Database Configuration
# Local development or Neon PostgreSQL url
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/society_maintenance

# Security & JWT Tokens
JWT_SECRET_KEY=super_secure_jwt_access_secret_key_change_me_in_production_123!
JWT_REFRESH_SECRET_KEY=super_secure_jwt_refresh_secret_key_change_me_in_production_123!
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Upload Directory
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# Complaint Settings
OVERDUE_THRESHOLD_DAYS=5

# Email Settings (SMTP/Brevo/Resend/Mailtrap)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=your_username
SMTP_PASSWORD=your_password
SMTP_FROM_EMAIL=noreply@societytracker.com
SMTP_FROM_NAME="Society Maintenance Tracker"

# CORS Allowed Origins (Comma separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
