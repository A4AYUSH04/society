PROJECT_NAME="Society Maintenance Tracker"
ENV=development

# Database Configuration (falls back to sqlite:///./society_maintenance.db if not reachable or not configured)
DATABASE_URL=sqlite:///./society_maintenance.db

# Security & JWT Tokens
JWT_SECRET_KEY=dev_secret_key_for_access_token_1234567890_antigravity
JWT_REFRESH_SECRET_KEY=dev_secret_key_for_refresh_token_1234567890_antigravity
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Upload Directory
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# Complaint Settings
OVERDUE_THRESHOLD_DAYS=5

# Email Settings (Using dummy settings for development by default)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@societytracker.com
SMTP_FROM_NAME="Society Maintenance Tracker"

# CORS Allowed Origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
